#include "xparameters.h"
#include "xil_io.h"
#include <stdint.h>

#define AWG_BASEADDR XPAR_AWG_AXI_0_S00_AXI_BASEADDR

#define REG_CONTROL     0x00
#define REG_PHASE_STEP  0x04
#define REG_AMP_OFFSET  0x08
#define REG_WAVE_WRITE  0x0C

#define CTRL_ENABLE     0x00000001
#define CTRL_RESET      0x00000002

static void awg_write_sample(uint16_t addr, int16_t sample)
{
    uint32_t word;
    word = ((uint32_t)(addr & 0x0FFF) << 16) | ((uint16_t)sample);
    Xil_Out32(AWG_BASEADDR + REG_WAVE_WRITE, word);
}

int main()
{
    /*
     * Minimalny program do symulacji:
     * - reset AWG,
     * - zapis 16 probek do BRAM,
     * - ustawienie phase_step tak, aby DDS czytal adresy 0,1,2,...,
     * - start generatora.
     */

    Xil_Out32(AWG_BASEADDR + REG_CONTROL, CTRL_RESET);
    Xil_Out32(AWG_BASEADDR + REG_CONTROL, 0x00000000);

    /*
     * 16 probek testowych. To nie musi byc ladny przebieg;
     * ma tylko sprawdzic tor: MicroBlaze -> AXI -> AWG -> sigma-delta.
     */
    awg_write_sample(0,  -25000);
    awg_write_sample(1,  -20000);
    awg_write_sample(2,  -12000);
    awg_write_sample(3,   -4000);
    awg_write_sample(4,    4000);
    awg_write_sample(5,   12000);
    awg_write_sample(6,   20000);
    awg_write_sample(7,   25000);
    awg_write_sample(8,   25000);
    awg_write_sample(9,   20000);
    awg_write_sample(10,  12000);
    awg_write_sample(11,   4000);
    awg_write_sample(12,  -4000);
    awg_write_sample(13, -12000);
    awg_write_sample(14, -20000);
    awg_write_sample(15, -25000);

    /*
     * Dla ADDR_BITS = 12 adres LUT jest brany z gornych 12 bitow
     * 32-bitowego akumulatora fazy.
     *
     * 0x00100000 = 2^(32-12), czyli adres LUT rosnie o 1 na takt:
     * 0, 1, 2, 3, ...
     *
     * Poprzednie 0x10000000 dawalo skok adresu o 256, wiec przy wpisaniu
     * tylko probek 0..15 rdzen prawie zawsze czytal niewypelnione miejsca.
     */
    Xil_Out32(AWG_BASEADDR + REG_PHASE_STEP, 0x00100000);

    /*
     * Amplituda ok. 0.75 w Q1.15, offset 0.
     */
    Xil_Out32(AWG_BASEADDR + REG_AMP_OFFSET, 0x00006000);

    /*
     * Start generatora.
     */
    Xil_Out32(AWG_BASEADDR + REG_CONTROL, CTRL_ENABLE);

    while (1)
    {
    }

    return 0;
}
